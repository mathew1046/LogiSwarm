# =============================================================================
# LogiSwarm Environment Configuration
# =============================================================================
# This file contains all environment variables used by LogiSwarm.
# Copy this to .env and fill in your values.
#
# IMPORTANT: Environment variables set in the shell take precedence over .env values.
# This allows deployment systems to override values without modifying .env.

# =============================================================================
# Python Configuration
# =============================================================================
# Force UTF-8 encoding for cross-platform compatibility (especially Windows)
PYTHONIOENCODING=utf-8

# =============================================================================
# LLM Configuration (Required for AI agent reasoning)
# =============================================================================
# Your LLM API key (Anthropic, OpenCode Go, OpenAI, etc.)
LLM_API_KEY=your-api-key-here

# LLM API base URL - supports multiple providers:
# - Anthropic: https://api.anthropic.com
# - OpenCode Go: https://opencode.ai/zen/go/v1 (use with OpenAI client format)
# - OpenAI: https://api.openai.com
# - Azure OpenAI: https://your-resource.openai.azure.com
# - Together AI: https://api.together.xyz/v1
# - Fireworks: https://api.fireworks.ai/inference/v1
LLM_BASE_URL=https://api.anthropic.com

# LLM model name - supported models depend on provider:
# - Anthropic: claude-sonnet-4-6, claude-3-haiku-20240307
# - OpenCode Go: minimax-m2.5, and other models available
# - OpenAI: gpt-4, gpt-3.5-turbo
# - Together/Fireworks: llama-3-70b, mixtral-8x7b
LLM_MODEL_NAME=claude-sonnet-4-6

# Example: Using OpenCode Go instead of Anthropic
# Uncomment these lines and add your OpenCode Go API key to use their models:
# LLM_API_KEY=your-opencode-api-key
# LLM_BASE_URL=https://opencode.ai/zen/go/v1
# LLM_MODEL_NAME=minimax-m2.5

# Maximum concurrent LLM calls (default: 5)
LLM_MAX_CONCURRENT=5

# Minimum seconds between agent reasoning cycles (default: 60)
LLM_MIN_CYCLE_INTERVAL=60

# Daily budget threshold for LLM calls in USD (default: 10.0)
LLM_DAILY_BUDGET_USD=10.0

# Fallback model when budget is exceeded (default: claude-3-haiku-20240307)
LLM_FALLBACK_MODEL=claude-3-haiku-20240307

# =============================================================================
# Database Configuration (Required)
# =============================================================================
# PostgreSQL connection string with asyncpg driver
DATABASE_URL=postgresql+asyncpg://logiswarm:logiswarm@localhost:5432/logiswarm

# Redis connection URL for pub/sub messaging
REDIS_URL=redis://localhost:6379

# TimescaleDB connection URL (for time-series data)
TIMESCALE_URL=postgresql://logiswarm:logiswarm@localhost:5432/logiswarm

# =============================================================================
# Zep Cloud Configuration (Episodic Memory)
# =============================================================================
# Zep Cloud API key for agent memory
ZEP_API_KEY=your-zep-api-key-here

# =============================================================================
# Port Sensors Configuration
# =============================================================================
# Enable mock mode for port sensor data (default: true)
PORT_MOCK_ENABLED=true

# =============================================================================
# TMS Webhook Configuration (Auto-Reroute)
# =============================================================================
# URL for TMS webhook to trigger reroutes
TMS_WEBHOOK_URL=

# HMAC secret for webhook authentication
TMS_WEBHOOK_SECRET=

# Webhook timeout in seconds (default: 8)
TMS_WEBHOOK_TIMEOUT_SECONDS=8

# Maximum retry attempts for webhook calls (default: 3)
TMS_WEBHOOK_MAX_RETRIES=3

# Redis key for dead letter queue
TMS_WEBHOOK_DLQ_KEY=dead_letter:tms:webhook

# =============================================================================
# Slack Integration
# =============================================================================
# Slack webhook URL for alert notifications
SLACK_WEBHOOK_URL=

# Slack webhook timeout in seconds (default: 8)
SLACK_WEBHOOK_TIMEOUT_SECONDS=8

# =============================================================================
# Email/SMTP Configuration (Alert Notifications)
# =============================================================================
# SMTP server hostname
SMTP_HOST=

# SMTP server port (default: 587 for TLS)
SMTP_PORT=587

# SMTP authentication username
SMTP_USERNAME=

# SMTP authentication password
SMTP_PASSWORD=

# Email sender address
SMTP_FROM_EMAIL=

# Use TLS for SMTP (default: true)
SMTP_USE_TLS=true

# Email alert throttle duration in seconds (default: 1800 = 30 minutes)
EMAIL_ALERT_THROTTLE_SECONDS=1800

# Comma-separated default email recipients
EMAIL_DEFAULT_RECIPIENTS=

# JSON mapping of project IDs to email recipient lists (default: {})
EMAIL_RECIPIENTS_BY_PROJECT_JSON={}

# =============================================================================
# Carrier API Configuration
# =============================================================================
# Carrier availability API URL
CARRIER_AVAILABILITY_API_URL=

# Carrier booking API URL
CARRIER_BOOKING_API_URL=

# Carrier API timeout in seconds (default: 8)
CARRIER_API_TIMEOUT_SECONDS=8

# Default carrier candidates for rebooking (comma-separated)
CARRIER_DEFAULT_CANDIDATES=maersk,cma-cgm,msc,hapag-lloyd

# =============================================================================
# Application Settings
# =============================================================================
# Environment mode (dev, staging, production)
ENVIRONMENT=dev

# Comma-separated CORS allowed origins (leave empty for dev mode to allow all)
CORS_ALLOW_ORIGINS=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO